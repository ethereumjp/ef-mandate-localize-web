# Copy to .env and fill in. .env is gitignored.
# Public (exposed to the browser):
# Registered ANNO schema UID on Sepolia — the widget queries comments by this id.
# Required to show real (on-chain) comments; leave empty to disable the widget.
PUBLIC_EAS_ANNO_SCHEMA_UID=
# Optional: custom Sepolia RPC for wallet writes (a public default is used if unset).
PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Script-only (NEVER commit a real key; use a throwaway testnet key):
SEPOLIA_PRIVATE_KEY=
