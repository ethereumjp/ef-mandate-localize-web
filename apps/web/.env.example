# Copy to .env and fill in. .env is gitignored.
#
# Public (exposed to the browser):
# Registered ANNO schema UID — the widget queries comments by this id. Register
# the schema once per network (same schema string → same UID on both chains).
# Required to show real (on-chain) comments; leave empty to disable the widget.
PUBLIC_EAS_ANNO_SCHEMA_UID=
#
# Network: mainnet by default; append `?mode=testnet` to a page URL to use Sepolia.
# Optional custom RPCs for wallet writes (public defaults used if unset):
PUBLIC_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
#
# Schema-registration script only — NEVER commit a real key:
#   NETWORK=mainnet|sepolia  EAS_PRIVATE_KEY=0x…  pnpm anno:schema:register
# (optional EAS_RPC_URL overrides the default node for that network)
EAS_PRIVATE_KEY=
