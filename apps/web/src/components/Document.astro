---
import Block from "./Block.astro";
import Index from "./Index.astro";
import SiteMeta from "./SiteMeta.astro";
import T from "./T.astro";
import { loadChapters, isPending } from "../lib/content";
import { withBase } from "../lib/i18n";
import type { Lang } from "../lib/i18n";
interface Props {
    lang: Lang;
}
const { lang } = Astro.props;
const chapters = loadChapters();

// The annotation widget is now an embedded <script> (built separately as
// @anno/widget → public/annotation/embed.js), so this site is "just
// another host". Inject it only when there's something to show: a registered
// ANNO schema, or mock mode for local preview.
const schemaUid = import.meta.env.PUBLIC_EAS_ANNO_SCHEMA_UID ?? "";
const mock = import.meta.env.PUBLIC_MOCK_COMMENTS ? "1" : undefined;
// Network is chosen at runtime by the widget (mainnet by default; `?mode=testnet`
// → Sepolia), so we don't pin data-network here — just pass both optional RPCs.
const rpc = import.meta.env.PUBLIC_SEPOLIA_RPC_URL;
const mainnetRpc = import.meta.env.PUBLIC_MAINNET_RPC_URL;
// Where to load the widget bundle from. Default: the same-origin copy produced by
// embed:build (good for local dev). Production: set PUBLIC_EMBED_SRC to the
// widget's own gateway URL so the widget deploys/updates independently of the site.
const embedSrc = import.meta.env.PUBLIC_EMBED_SRC || withBase("annotation/embed.js");
const annotationEnabled = Boolean(schemaUid) || Boolean(mock);
---

<div
    class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-8 md:flex-row md:py-12"
>
    <aside id="index" class="scroll-mt-20 md:w-56 md:shrink-0">
        <div
            class="md:sticky md:top-20 md:flex md:h-[calc(100dvh-5rem)] md:flex-col md:overflow-y-auto md:pb-8"
        >
            <details
                class="rounded border border-stone-200 dark:border-stone-800 md:hidden"
            >
                <summary
                    class="cursor-pointer px-3 py-2 text-sm font-semibold uppercase tracking-wide text-stone-500 dark:text-stone-400"
                >
                    <T k="index" />
                </summary>
                <div
                    class="border-t border-stone-200 dark:border-stone-800 p-2"
                >
                    <Index chapters={chapters} lang={lang} />
                </div>
            </details>
            <div class="hidden md:block">
                <h2
                    class="text-sm font-semibold uppercase tracking-wide text-stone-500 dark:text-stone-400"
                >
                    <T k="index" />
                </h2>
                <div class="mt-3">
                    <Index chapters={chapters} lang={lang} />
                </div>
            </div>
            <div
                class="mt-8 hidden border-t border-stone-200 pt-6 dark:border-stone-800 md:mt-auto md:block"
            >
                <SiteMeta lang={lang} />
            </div>
        </div>
    </aside>

    <main class="min-w-0 space-y-16 font-serif md:max-w-3xl">
        {
            chapters.map((ch) => (
                <section id={`ch-${ch.number}`} class="scroll-mt-24">
                    {isPending(ch, lang) && (
                        <p class="mb-6 rounded border border-stone-200 bg-stone-50 px-3 py-2 text-sm text-stone-500 dark:border-stone-700 dark:bg-stone-800/50 dark:text-stone-400">
                            <T k="pending" />
                        </p>
                    )}
                    <div class="space-y-6">
                        {ch.blocks.map((block) => (
                            <Block block={block} lang={lang} />
                        ))}
                    </div>
                    <p class="mt-6 text-right">
                        <a
                            href="#index"
                            class="text-stone-400 hover:text-stone-600 dark:text-stone-500 dark:hover:text-stone-300"
                        >
                            <span class="sr-only">
                                <T k="backToIndex" />
                            </span>
                            <span aria-hidden="true">↑</span>
                        </a>
                    </p>
                </section>
            ))
        }
    </main>
</div>
<footer
    class="mx-auto max-w-6xl border-t border-stone-200 px-4 py-8 dark:border-stone-800 md:hidden"
>
    <SiteMeta lang={lang} />
</footer>
{
    annotationEnabled && (
        <script
            is:inline
            type="module"
            src={embedSrc}
            data-schema-uid={schemaUid}
            data-lang={lang}
            data-mock={mock}
            data-rpc={rpc}
            data-mainnet-rpc={mainnetRpc}
        />
    )
}
