{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "paths": {
      "@anno/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src", "scripts", "tests"],
  "exclude": ["dist", ".astro"]
}
