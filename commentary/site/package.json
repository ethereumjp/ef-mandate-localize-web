{
  "name": "@commentary/site",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "scripts": {
    "dev": "pnpm run embed:build && astro dev",
    "dev:mock": "pnpm run embed:build && PUBLIC_MOCK_COMMENTS=1 astro dev",
    "build": "pnpm run embed:build && astro build",
    "preview": "astro preview",
    "embed:build": "pnpm -C ../widget run build && pnpm run embed:copy",
    "embed:copy": "rm -rf public/commentary && mkdir -p public/commentary && cp -R ../widget/dist/. public/commentary/",
    "typecheck": "tsc --noEmit",
    "check:astro": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src scripts tests",
    "fmt": "oxfmt 'src/**/*.ts' 'src/**/*.tsx' 'scripts/*.ts' 'tests/*.ts'",
    "fmt:check": "oxfmt --check 'src/**/*.ts' 'src/**/*.tsx' 'scripts/*.ts' 'tests/*.ts'",
    "anno:schema:register": "tsx scripts/register-anno-schema.ts",
    "gen:mock": "tsx scripts/gen-mock-comments.ts",
    "deploy": "bash scripts/deploy-pages.sh"
  },
  "dependencies": {
    "@commentary/core": "workspace:*",
    "@ethereum-attestation-service/eas-sdk": "^2.9.1",
    "astro": "^6.4.4",
    "ethers": "^6.16.0",
    "marked": "^14.1.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.5.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
