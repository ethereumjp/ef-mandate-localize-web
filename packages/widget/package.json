{
  "name": "@anno/widget",
  "version": "0.1.0",
  "type": "module",
  "description": "Embeddable on-chain annotation widget — drop a <script> on any page and readers can attach wallet-signed comments anchored to the exact text span they select, stored as EAS attestations.",
  "license": "MIT",
  "homepage": "https://github.com/ethereumjp/ef-mandate-localize-web/tree/main/packages/widget#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereumjp/ef-mandate-localize-web.git",
    "directory": "packages/widget"
  },
  "keywords": [
    "annotation",
    "comments",
    "eas",
    "ethereum",
    "attestation",
    "widget",
    "embed",
    "web3"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/embed.js",
  "module": "./dist/embed.js",
  "exports": {
    ".": "./dist/embed.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "serve:test": "python3 -m http.server 5180"
  },
  "dependencies": {},
  "devDependencies": {
    "@anno/core": "workspace:*",
    "@base-ui-components/react": "1.0.0-rc.0",
    "@ethereum-attestation-service/eas-sdk": "^2.9.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ethers": "^6.16.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "viem": "^2.21.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.9",
    "wagmi": "^3.6.16"
  }
}
