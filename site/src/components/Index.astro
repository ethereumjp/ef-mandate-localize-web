---
import type { Chapter } from "../lib/content";
import type { Lang } from "../lib/i18n";
interface Props {
  chapters: Chapter[];
  lang: Lang;
}
const { chapters, lang } = Astro.props;
---
<ol class="divide-y divide-stone-200 text-sm">
  {chapters.map((ch) => (
    <li>
      <a
        href={`#ch-${ch.number}`}
        class="block py-2 text-stone-600 hover:text-stone-900"
      >
        {lang === "ja" ? (ch.jaTitle ?? ch.title) : ch.title}
      </a>
    </li>
  ))}
</ol>
