---
import { MESSAGES, LANG_OPTIONS } from "../lib/i18n";
import type { Lang } from "../lib/i18n";
interface Props {
    lang: Lang;
}
const { lang } = Astro.props;
---

<header
    class="sticky top-0 z-10 border-b bg-stone-50/90 border-stone-200/90 backdrop-blur dark:border-stone-700/90 dark:bg-stone-800/90"
>
    <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3"
    >
        <a href="/" class="whitespace-nowrap font-bold text-2xl tracking-tight"
            >{MESSAGES.en.siteTitle}</a
        >
        <div class="flex items-center gap-3 text-sm">
            <span id="wallet-slot"></span>
            <select
                data-lang-select
                aria-label={MESSAGES[lang].language}
                class="rounded border border-stone-300 bg-transparent px-2 py-1 text-sm hover:bg-stone-100 dark:border-stone-700 dark:hover:bg-stone-800"
            >
                {
                    LANG_OPTIONS.map((opt) => (
                        <option value={opt.route} selected={lang === opt.code}>
                            {opt.label}
                        </option>
                    ))
                }
            </select>
            <button
                data-toggle-comments
                type="button"
                role="switch"
                aria-label={MESSAGES[lang].comments}
                class="flex items-center gap-2 rounded px-1.5 py-1 text-sm hover:bg-stone-100 dark:hover:bg-stone-800"
            >
                <svg
                    class="size-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337Z"
                    ></path>
                </svg>
                <span
                    class="comments-switch relative inline-block h-5 w-9 shrink-0 rounded-full bg-stone-300 transition-colors dark:bg-stone-600"
                >
                    <span
                        class="comments-switch-knob absolute top-0.5 left-0.5 size-4 rounded-full bg-white shadow transition-transform"
                    ></span>
                </span>
            </button>
            <button
                data-toggle-theme
                aria-label="Toggle dark mode"
                class="rounded p-1.5 hover:bg-stone-100 dark:hover:bg-stone-800"
            >
                <svg
                    class="size-4 dark:hidden"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
                    ></path>
                </svg>
                <svg
                    class="hidden size-4 dark:block"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
                    ></path>
                </svg>
            </button>
        </div>
    </div>
    <script>
        import "../scripts/toggles.ts";
    </script>
</header>
