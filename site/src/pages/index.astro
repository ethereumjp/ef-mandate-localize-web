---
import Reading from "../layouts/Reading.astro";
import Block from "../components/Block.astro";
import Index from "../components/Index.astro";
import T from "../components/T.astro";
import { loadChapters } from "../lib/content";
const chapters = loadChapters();
---
<Reading title="EF Mandate">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-8 md:flex-row md:py-12">
    <!-- Index: a click-to-expand menu on small screens, a sticky sidebar on desktop. -->
    <aside id="index" class="scroll-mt-20 md:w-56 md:shrink-0">
      <div class="md:sticky md:top-20">
        <details class="rounded border border-stone-200 md:hidden">
          <summary class="cursor-pointer px-3 py-2 text-sm font-semibold uppercase tracking-wide text-stone-500">
            <T k="index" />
          </summary>
          <div class="border-t border-stone-200 p-2">
            <Index chapters={chapters} />
          </div>
        </details>
        <div class="hidden md:block">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-stone-500">
            <T k="index" />
          </h2>
          <div class="mt-3">
            <Index chapters={chapters} />
          </div>
        </div>
      </div>
    </aside>

    <!-- Reading column: all chapters on one page. -->
    <main class="min-w-0 space-y-16 md:max-w-3xl">
      {chapters.map((ch) => (
        <section id={`ch-${ch.number}`} class="scroll-mt-24">
          {ch.jaPending && (
            <p class="lang lang-ja mb-6 rounded border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-800">
              <T k="jaPending" />
            </p>
          )}
          <div class="space-y-6">
            {ch.blocks.map((block) => <Block block={block} />)}
          </div>
          <p class="mt-6 text-right">
            <a href="#index" class="text-xs text-stone-400 hover:text-stone-600">
              <T k="backToIndex" /> ↑
            </a>
          </p>
        </section>
      ))}
    </main>
  </div>
</Reading>
