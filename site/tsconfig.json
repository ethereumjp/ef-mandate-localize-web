{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src", "scripts", "tests"],
  "exclude": ["dist", ".astro"]
}
